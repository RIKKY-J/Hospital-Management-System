{
  "name": "hospital-system",
  "version": "1.0.0",
  "main": "server.js",
  "description": "City Hospital Management System — Full project with Allure Quality Reporting",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "test": "mocha --reporter mocha-allure-reporter --timeout 40000 test/*.js",
