    "allure-mocha": "^3.4.2",
    "chai": "^6.2.0",
    "chromedriver": "^142.0.1",
    "mocha": "^11.7.5",
    "mocha-allure-reporter": "^1.4.0",
    "selenium-webdriver": "^4.38.0"
  },
  "keywords": ["hospital", "management", "system", "selenium", "mocha", "allure", "testing"],
